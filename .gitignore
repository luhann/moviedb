# Cargo build artifacts
/target

# rustfmt backup files
*.rs.bk

# Local SQLite databases (WAL mode also creates -shm/-wal sidecars)
*.db
*.db-shm
*.db-wal

# Secrets — dist/moviedb.env.example is a template, not a real credential
*.env

# scripts/migrate_dynamo.py and tests/smoke_test.py are stdlib-only, but
# harmless to guard against anyway
__pycache__/

.vscode/
.claude/
